<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" GridPane.columnIndex="0">
      <padding>
        <Insets top="5" right="5" bottom="5" left="15" />
      </padding>
      <HBox spacing="6" alignment="CENTER_LEFT">
        <Label fx:id="rowNumber" styleClass="cell_big_label" text="Index 1.">
          <!-- Ensures that the label text is never truncated -->
          <minWidth>
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="role" styleClass="cell_big_label" text="\$role" />
        <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="personIdLabel" styleClass="cell_small_label" text="(ID: 1)">
          <minWidth>
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
      </HBox>
      <FlowPane fx:id="sex" />
      <FlowPane fx:id="allergies" />
      <Label fx:id="nric" styleClass="cell_small_label" text="\$nric" />
      <Label fx:id="phone" styleClass="cell_small_label" text="\$phone" />
      <Label fx:id="address" styleClass="cell_small_label" text="\$address" />
      <Label fx:id="email" styleClass="cell_small_label" text="\$email" />
    </VBox>
  </GridPane>
</HBox>
