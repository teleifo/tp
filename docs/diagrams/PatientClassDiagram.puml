@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Class Person
Class ContactPerson
Class Patient
Class Name
Class Phone
Class Email
Class Address
Class Tag
Class NRIC
Class Diagnosis


ContactPerson --|> Person
Patient --|> ContactPerson
Person *--> "1" Name
