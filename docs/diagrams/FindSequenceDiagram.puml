@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":ClinicBookParser" as ClinicBookParser LOGIC_COLOR
participant ":FindCommandParser" as FindCommandParser LOGIC_COLOR
participant "c:FindCommand" as FindCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "pred:PersonMatchesFindCriteriaPredicate" as Predicate MODEL_COLOR
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("find n/Alice Bob")
activate LogicManager

LogicManager -> ClinicBookParser : parseCommand("find n/Alice Bob")
activate ClinicBookParser

create FindCommandParser
ClinicBookParser -> FindCommandParser
activate FindCommandParser

FindCommandParser --> ClinicBookParser
deactivate FindCommandParser

ClinicBookParser -> FindCommandParser : parse(" n/Alice Bob")
activate FindCommandParser

FindCommandParser -> FindCommandParser : tokenize and validate\narguments

create Predicate
FindCommandParser -> Predicate : create predicate for\n["Alice", "Bob"]
activate Predicate

Predicate --> FindCommandParser
deactivate Predicate

create FindCommand
FindCommandParser -> FindCommand : new FindCommand(pred)
activate FindCommand

FindCommand --> FindCommandParser : c
deactivate FindCommand

FindCommandParser --> ClinicBookParser : c
deactivate FindCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
FindCommandParser -[hidden]-> ClinicBookParser
destroy FindCommandParser

ClinicBookParser --> LogicManager : c
deactivate ClinicBookParser

LogicManager -> FindCommand : execute(model)
activate FindCommand

FindCommand -> Model : updateFilteredPersonList(pred)
activate Model

Model --> FindCommand
deactivate Model

create CommandResult
FindCommand -> CommandResult
activate CommandResult

CommandResult --> FindCommand
deactivate CommandResult

FindCommand --> LogicManager : r
deactivate FindCommand

[<-- LogicManager
deactivate LogicManager
@enduml
