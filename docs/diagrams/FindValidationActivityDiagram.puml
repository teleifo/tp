@startuml
skin rose
skinparam ActivityFontSize 15
skinparam ArrowFontSize 12

start
:Tokenize arguments using
`n/`, `p/`, and `nric/`;

if () then ([duplicate search prefix])
  :Reject with duplicate-prefix error;
  stop
else ([else])
endif

if () then ([exactly one search prefix
and no preamble])
else ([else])
  :Reject with invalid
  command format;
  stop
endif

if () then ([selected prefix is `n/`])
  if () then ([name value blank])
    :Reject with invalid
    command format;
    stop
  else ([else])
    :Split value into
    name keywords;
  endif
else ([else])
  if () then ([selected prefix is `p/`])
    :Parse phone value;
    if () then ([phone invalid])
      :Reject with phone
      format error;
      stop
    else ([else])
    endif
  else ([selected prefix is `nric/`])
    :Parse NRIC value;
    if () then ([NRIC invalid])
      :Reject with NRIC
      format error;
      stop
    else ([else])
    endif
  endif
endif

:Create matching
predicate;
:Create FindCommand;
stop
@enduml
